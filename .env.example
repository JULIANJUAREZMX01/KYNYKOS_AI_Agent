# Telegram Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=01234567890

# WhatsApp Bridge (Twilio)
# 1. Sign up at https://www.twilio.com and go to Messaging → Try it out → Send a WhatsApp message
# 2. Enable the WhatsApp Sandbox and note your Account SID and Auth Token
# 3. TWILIO_WHATSAPP_FROM is the Twilio sandbox number (shown in the sandbox setup page)
# 4. TWILIO_WHATSAPP_TO is YOUR WhatsApp number (owner's number for proactive alerts)
# 5. Send "join <sandbox-keyword>" to the sandbox number from your phone to activate it
# 6. Set the Sandbox Webhook URL in Twilio to: https://<your-service>.onrender.com/api/webhook/whatsapp
# Docs: https://www.twilio.com/docs/whatsapp/sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_TO=+521XXXXXXXXXX

# LLM Router Configuration (Ollama-primary with fallback chain)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

GROQ_API_KEY=gsk-...
GROQ_MODEL=mixtral-8x7b

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

LLM_CONFIG_PATH=app/config/llm_config.yaml
LLM_ROTATION_STRATEGY=round_robin

# AWS S3 Configuration (for backups)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Application
PORT=8000
HOST=0.0.0.0
