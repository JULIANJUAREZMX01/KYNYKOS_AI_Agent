# ============================================================
# KynicOS / KYNYKOS_AI_Agent — Environment Variables
# ============================================================

# Personalidad activa: kynikos | leo | mueve | nexus
PERSONA=kynikos

# ── Telegram (REQUERIDO) ──────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_USER_ID=8247886073
# Chat ID del técnico para escalación HVAC (opcional)
TECH_TELEGRAM_CHAT_ID=

# ── LLM — Groq (REQUERIDO, gratis) ───────────────────────────
# Regístrate en: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM — Together AI (FALLBACK gratis) ──────────────────────
# Regístrate en: https://api.together.xyz ($25 créditos gratis)
TOGETHER_API_KEY=

# ── LLM — OpenRouter (FALLBACK modelos públicos gratuitos) ───
# Regístrate en: https://openrouter.ai (modelos :free disponibles)
OPENROUTER_API_KEY=

# ── Ollama local (opcional, sin costo ni límites) ─────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── WhatsApp Twilio (opcional) ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_TO=

# ── Stripe Connect (Fase 2 — pagos) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_COMMISSION_PERCENTAGE=5

# ── AWS S3 (backups opcionales) ───────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=8000
