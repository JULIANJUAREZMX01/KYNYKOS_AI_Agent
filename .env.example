# Telegram Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=01234567890

# WhatsApp Bridge (Twilio)
# Sign up at https://www.twilio.com and enable the WhatsApp Sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_TO=+521XXXXXXXXXX

# LLM Providers (Groq primary, Anthropic fallback)
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS S3 Configuration (for backups)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Application
PORT=8000
HOST=0.0.0.0
